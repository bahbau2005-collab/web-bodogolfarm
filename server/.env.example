# Environment Configuration for Bodogol Farm Backend
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bodogol-farm
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/bodogol-farm

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRE=7d

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Redis untuk rate limiter (opsional, disarankan di production/serverless).
# Pakai Upstash (gratis): rediss://default:<token>@<host>:6379
# Kosongkan untuk pakai memory store (cukup untuk lokal).
REDIS_URL=

# Secret untuk endpoint cron (auto-batalkan booking pending kedaluwarsa).
# Set string acak; cron (Vercel/eksternal) kirim header: Authorization: Bearer <secret>
CRON_SECRET=

# Email Configuration (SMTP) — untuk notifikasi e-ticket via email.
# Gmail:  EMAIL_HOST=smtp.gmail.com  EMAIL_PORT=465  (EMAIL_PASS = App Password, butuh 2FA)
# Brevo:  EMAIL_HOST=smtp-relay.brevo.com  EMAIL_PORT=587
# Kosongkan/biarkan default kalau belum dipakai (email otomatis di-skip).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Bodogol Farm <your-email@gmail.com>

# Midtrans Payment Configuration (Sandbox)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false