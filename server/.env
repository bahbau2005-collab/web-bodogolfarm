# Environment Configuration for Bodogol Farm Backend
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bodogol-farm
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/bodogol-farm

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRE=7d

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Email Configuration (for future use)
EMAIL_SERVICE=gmail

# Midtrans Payment Configuration
MIDTRANS_SERVER_KEY=SB-Mid-server-T9mTvfjFKsJ7KvM3Z3x6w8QK
MIDTRANS_CLIENT_KEY=SB-Mid-client-Mid-server-T9mTvfjFKsJ7KvM3Z3x6w8QK
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Midtrans Payment Configuration (for future use)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false